# Copy this file to .env and fill in your values.
# Get these from: Supabase Dashboard → your project → Settings → API
# IMPORTANT: Use the "anon" "public" key (long JWT starting with eyJ...).
# Do NOT use "publishable" or "sb_publishable_..." — that is not the API key.

# Project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# anon public key (long JWT, starts with eyJ... — NOT the sb_publishable_... value)
VITE_SUPABASE_ANON_KEY=your_anon_jwt_here

# Optional: Google API key for address autocomplete, pro service-area map, "serves your area", and geocoding (postal code → sort pros by distance).
# Enable "Geocoding API" and "Places API" in Google Cloud Console. Restrict to HTTP referrers: https://www.premiereservices.ca/* and http://localhost:*
# VITE_GOOGLE_PLACES_API_KEY=your_google_api_key
# Or: VITE_GOOGLE_MAPS_API_KEY=your_google_api_key

# Square (for booking payments). See docs/SQUARE-SETUP.md for where to find credentials.
# Application ID (frontend) — Developer Dashboard → Applications → your app → Credentials → Application ID:
# VITE_SQUARE_APPLICATION_ID=sandbox-sq0idb-...
# Location ID (frontend) — Developer Dashboard or Square Dashboard → Locations:
# VITE_SQUARE_LOCATION_ID=L...
# Access token: NEVER in frontend. Add in Supabase Dashboard → Edge Functions → square-create-payment → Secrets: SQUARE_ACCESS_TOKEN
